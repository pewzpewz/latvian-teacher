        { "lv": "draugs / draudzene", "ru": "друг / подруга" }
      ]
    },
    {
      "title": "Возраст",
      "content": "Чтобы сказать возраст: «Man ir X gadi» — «Мне X лет».",
      "examples": [
        { "lv": "Man ir trīsdesmit gadi.", "ru": "Мне тридцать лет." },
        { "lv": "Viņam ir pieci gadi.", "ru": "Ему пять лет." }
      ],
      "tip": "Слово «gads» склоняется: 1 gads, 2–9 gadi, 10+ gadu."
    }
  ],
