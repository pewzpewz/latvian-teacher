# Google Gemini (рекомендуется, бесплатно ~1500 запросов/день)
# Получить ключ: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Провайдер: gemini | openai | anthropic | local
AI_PROVIDER=gemini

# Модель (для Gemini: gemini-2.5-flash, gemini-2.0-flash)
AI_MODEL=gemini-3-flash-preview

# Альтернативы (если нужны):
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Для Ollama (локальный AI)
# OLLAMA_URL=http://localhost:11434

# Порт сервера
PORT=3001

# --- Безопасность (обязательно при доступе из интернета) ---

# Разрешённые origin'ы через запятую (dev по умолчанию)
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001,https://your-tunnel.example.com

# Токен доступа к API (если задан — клиент должен слать X-Access-Token)
# API_ACCESS_TOKEN=your-random-secret

# Live WebSocket лимиты
# LIVE_MAX_CONNECTIONS=20
# LIVE_IDLE_TIMEOUT_MS=300000
# LIVE_PING_INTERVAL_MS=30000
# LIVE_UTTERANCE_COOLDOWN_MS=1500
