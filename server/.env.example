# Google Gemini (рекомендуется, бесплатно ~1500 запросов/день)
# Получить ключ: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Провайдер: gemini | openai | anthropic | local
AI_PROVIDER=gemini

# Модель (для Gemini: gemini-2.5-flash, gemini-2.0-flash)
AI_MODEL=gemini-3-flash-preview

# Альтернативы (если нужны):
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Для Ollama (локальный AI)
# OLLAMA_URL=http://localhost:11434

# Порт сервера
PORT=3001
